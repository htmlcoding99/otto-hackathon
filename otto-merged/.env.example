# ── OTTO 2.0 · Server Environment ────────────────────────────────────────────
# Copy to .env and fill in your keys. Leave unused providers blank.
# Run with: node server.js

# ── LLM PROVIDER PRIORITY ────────────────────────────────────────────────────
# Primary provider: openai | claude | groq
# System tries providers in order until one succeeds.
LLM_PROVIDER=groq

# ── OPENAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_ORG_ID=

# ── ANTHROPIC (CLAUDE) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── GROQ ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=

# ── PER-AGENT MODEL ASSIGNMENT ────────────────────────────────────────────────
# Planner and Budget use fast/cheap models; Decision uses stronger reasoning.
MODEL_PLANNER=llama-3.1-8b-instant          # groq fast | claude-3-haiku | gpt-4o-mini
MODEL_RESEARCH=llama-3.1-8b-instant         # groq fast | claude-3-haiku | gpt-4o-mini
MODEL_BUDGET=llama-3.1-8b-instant           # groq fast | claude-3-haiku | gpt-4o-mini
MODEL_DECISION=llama-3.3-70b-versatile      # groq big  | claude-3-5-sonnet | gpt-4o

# ── EXA SEARCH (optional) ─────────────────────────────────────────────────────
# Leave blank to use the built-in mock search.
EXA_API_KEY=

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=3001

# ── STRIPE PAYMENTS ───────────────────────────────────────────────────────────
# If true, the system will simulate checkouts without requiring Stripe keys.
# Set to false and provide keys for production checkout.
STRIPE_MOCK_MODE=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── RESEND EMAIL (optional) ───────────────────────────────────────────────────
# Powers POST /api/notify ("Email me this" on the receipt). One API call.
# Free key works instantly with the onboarding@resend.dev sender; until you
# verify a domain, Resend only delivers to your own Resend account address.
RESEND_API_KEY=                              # https://resend.com/api-keys (re_…)
RESEND_FROM=                                 # e.g. "OTTO <otto@yourdomain.com>" — defaults to onboarding@resend.dev
